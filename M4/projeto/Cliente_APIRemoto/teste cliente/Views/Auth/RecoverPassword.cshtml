@model teste_cliente.Models.RecoverPassword
@{
    ViewData["Title"] = "Recover password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<br />
<div class="fix-wrapper">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">
                <div class="card mb-0 h-auto">
                    <div class="card-body">
                       
                        <h4 class="text-center mb-4">Recuperar password</h4>

                        <hr class="mt-4 mb-5" style="border-top: 1px solid #e0e0e0; opacity: 0.8;" />

                        <div asp-validation-summary="ModelOnly" class="text-danger text-center"></div>

                        <form asp-controller="Auth" asp-action="RequestResetPassword" method="post">
                            <input type="hidden" asp-for="Token" />
                            <input type="hidden" asp-for="UserId" />

                            <div class="form-group mb-4">
                                <label class="form-label" asp-for="Password">Nova password</label>
                                <input asp-for="Password" type="password" class="form-control" />
                                <span asp-validation-for="Password" class="text-warning"></span>
                            </div>

                            <div class="form-group mb-4">
                                <label class="form-label" asp-for="ConfirmPassword">Confirmar password</label>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                                <span asp-validation-for="ConfirmPassword" class="text-warning"></span>
                            </div>

                            <div class="form-group mt-3 d-flex justify-content-between align-items-center">
                                <a asp-action="Login" asp-controller="Auth" class="btn-back-outline">Login</a>
                                <button type="submit" class="btn-reset">Mudar password</button>
                            </div>
                        </form>
                        <br />
                        <flash dismissable="true" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    /* Botão Principal (Reset) */
    .btn-reset {
        background-color: #F89B3D;
        color: white;
        border: 2px solid #F89B3D; /* Borda da mesma cor para alinhar tamanhos */
        border-radius: 30px;
        padding: 0.6rem 1.5rem; /* Aumentei o padding lateral, mas removi o width fixo */
        font-size: 0.85rem;
        font-weight: bold;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
        white-space: nowrap; /* Garante que o texto não quebra */
    }

        .btn-reset:hover {
            background-color: #5de4d9;
            border-color: #5de4d9;
            color: white;
        }

    /* Botão Outline (Back to Login) */
    .btn-back-outline {
        background-color: transparent;
        color: #F89B3D;
        border: 2px solid #F89B3D; /* Borda laranja */
        border-radius: 30px;
        padding: 0.6rem 1.5rem;
        font-size: 0.85rem;
        font-weight: bold;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

        .btn-back-outline:hover {
            background-color: #F89B3D;
            color: white;
            text-decoration: none;
        }
</style>
