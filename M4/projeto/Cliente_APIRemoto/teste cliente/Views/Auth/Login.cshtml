@model teste_cliente.DTOs.LoginRequestDTO;
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

<script src="https://accounts.google.com/gsi/client" async defer></script>

<div class="modal-overlay" id="loginModal">
    <div class="modal-content" id="modalContent">
        <button class="close-btn" id="closeModalBtn">&times;</button>

        <h3>Login</h3>

        <form asp-controller="Auth" asp-action="Login" method="post" id="loginForm">
            <div asp-validation-summary="All" class="text-danger text-center mb-2"></div>

            <input asp-for="UserName" type="text" class="form-control" placeholder="Username..." />
            <input asp-for="Password" type="password" class="form-control" placeholder="Password..." />

            <div class="btn-group">
                <button type="submit" class="btn-register">Login</button>

                @* _________ADIÇÃO DE CÓDIGO__________(ForgotPassword)*@
                <a href="@Url.Action("ForgotPassword")" class="btn-register">Recuperar Password</a>
            </div>
           
        </form>

        <div class="separator">ou</div>

        <div class="google-btn-container">
            <div id="g_id_onload"
                 data-client_id="@Configuration["Authentication:Google:ClientId"]"
                 data-context="signin"
                 data-ux_mode="popup"
                 data-callback="handleCredentialResponse"
                 data-auto_prompt="false">
            </div>

            <div class="g_id_signin"
                 data-type="standard"
                 data-shape="pill"
                 data-theme="outline"
                 data-text="signin_with"
                 data-size="large"
                 data-logo_alignment="left"
                 data-width="300">
            </div>
        </div>
    </div>
</div>

<style>
    .separator {
        display: flex;
        align-items: center;
        text-align: center;
        margin: 1.5rem 0;
        color: #999;
        font-size: 0.9rem;
    }

    .separator::before,
    .separator::after {
        content: '';
        flex: 1;
        border-bottom: 1px solid #ddd;
    }

    .separator:not(:empty)::after {
        margin-left: .5em;
    }

    .google-btn-container {
        display: flex;
        justify-content: center;
        margin-top: 10px;
    }

    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: linear-gradient(to bottom right, #00B8D4, #6EE5E9);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
        animation: fadeIn 0.3s ease-in-out;
    }

    .modal-content {
        background-color: white;
        border-radius: 20px;
        padding: 2rem;
        width: 90%;
        max-width: 360px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        position: relative;
        animation: slideDown 0.3s ease-in-out;
    }

    .form-control {
        margin-bottom: 1rem;
        border-radius: 10px;
    }

    .btn-register {
        background-color: #F89B3D;
        color: white;
        border: none;
        border-radius: 30px;
        padding: 0.6rem 1.2rem;
        width: 50%;
        font-weight: bold;
        margin: 0 auto; 
        display: block;
        text-align: center;
        text-decoration: none; /* Keeps the 'a' tag from having an underline */
    }

    .btn-register:hover {
        background-color: #5de4d9;
        color: white;
    }

    .close-btn {
        position: absolute;
        top: 12px;
        right: 16px;
        font-size: 1.4rem;
        cursor: pointer;
        border: none;
        background: none;
        color: #999;
    }

    h3 {
        text-align: center;
        margin-bottom: 1rem;
        font-weight: 600;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function handleCredentialResponse(response) {
            const googleToken = response.credential;

            const tokenElement = document.querySelector('input[name="__RequestVerificationToken"]');
            const verificationToken = tokenElement ? tokenElement.value : '';

            fetch('/Auth/GoogleLogin', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': verificationToken
                },
                body: JSON.stringify(googleToken)
            })
            .then(res => res.json())
            .then(data => {
                if (data.isSuccess) {
                    window.location.href = data.redirectUrl;
                } else {
                    alert(data.message || 'Erro ao fazer login com o Google.');
                }
            })
            .catch(err => {
                console.error('Erro no login do Google:', err);
                alert('Ocorreu um erro ao comunicar com o servidor.');
            });
        }
    </script>
}